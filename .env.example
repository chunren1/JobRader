# ============================================
# JobRadar 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入实际值
# CP:   .env.example -> .env.local
# ============================================

# 数据库连接 (PostgreSQL)
# 开发环境可使用本地 PostgreSQL 或 Supabase/Turso
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobradar"

# 直接数据库 URL (用于 Prisma migrate)
DIRECT_URL="postgresql://postgres:password@localhost:5432/jobradar"

# ============================================
# AI 服务配置 (二选一)
# ============================================
# OpenAI
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL="gpt-4o-mini"

# Anthropic Claude (备选)
# ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# ANTHROPIC_MODEL="claude-3-haiku-20240307"

# ============================================
# 安全配置
# ============================================
# Extension 与 Next.js 之间的本地共享密钥 (X-Local-Secret)
LOCAL_SECRET="job-radar-local-dev-secret-change-me"

# Vercel Cron 触发密钥 (保护 Worker 路由不被外部滥用)
CRON_SECRET="job-radar-cron-secret-change-me"

# ============================================
# AI 用户画像 (用于 AI 评分时的参考上下文)
# ============================================
USER_RESUME_SUMMARY="5年全栈开发经验，熟悉 React/Next.js/Node.js"
USER_PREFERENCES="远程办公、AI/LLM方向、B轮以上"
USER_EXPECTED_SALARY="30-50K"
USER_EXPECTED_LOCATION="北京、上海、深圳、杭州"

# ============================================
# Next.js 配置
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
