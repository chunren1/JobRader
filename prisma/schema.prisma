// ============================================
// JobRadar Prisma Schema
// 默认: SQLite (零配置, 开箱即用)
// 可选: PostgreSQL (见 docker-compose.yml)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// 岗位主表
// ============================================
model Job {
  id               String   @id @default(cuid())
  title            String
  company          String
  salaryMin        Int?
  salaryMax        Int?
  location         String
  jdContent        String
  tags             String   @default("[]")          // JSON 数组, 如 ["React","TypeScript"]
  rawUrl           String   @unique
  source           String   @default("platform")

  aiScore          Int?
  aiSummary        String?
  aiRecommendation String?
  aiTechMatch      String   @default("[]")          // JSON 数组
  aiRedFlags       String   @default("[]")          // JSON 数组
  aiSalaryMatch    String?
  aiDimensions     String?                           // JSON 对象字符串

  analyzedAt       DateTime?
  fetchedAt        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  favorites        UserFavorite[]
  analysisTask     AiAnalysisTask?

  @@index([aiScore])
  @@index([location])
  @@index([fetchedAt])
  @@index([createdAt])
  @@map("jobs")
}

// ============================================
// 用户收藏表 (支持软删除)
// ============================================
model UserFavorite {
  id        String    @id @default(cuid())
  jobId     String
  notes     String?
  tags      String    @default("[]")                // JSON 数组
  deletedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("user_favorites")
}

// ============================================
// AI 分析任务队列表
// ============================================
model AiAnalysisTask {
  id         String   @id @default(cuid())
  jobId      String   @unique
  status     String   @default("pending")
  retryCount Int      @default(0)
  maxRetries Int      @default(3)
  errorMsg   String?
  lockKey    String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("ai_analysis_tasks")
}

// ============================================
// AI 分析结果缓存表
// ============================================
model AiAnalysisCache {
  id               String   @id @default(cuid())
  jdHash           String   @unique
  aiScore          Int
  aiSummary        String
  aiRecommendation String
  aiTechMatch      String   @default("[]")          // JSON 数组
  aiRedFlags       String   @default("[]")          // JSON 数组
  aiSalaryMatch    String?
  aiDimensions     String?                           // JSON 对象字符串
  hitCount         Int      @default(1)

  createdAt        DateTime @default(now())

  @@index([jdHash])
  @@map("ai_analysis_cache")
}

// ============================================
// 求职者简历
// ============================================
model Resume {
  id         String   @id @default(cuid())
  rawText    String                            // PDF 原始文本
  structured String   @default("{}")           // AI提取的结构化JSON
  fileName   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("resumes")
}
